{
  "name": "@inventure71/paddockjs",
  "version": "0.1.0",
  "type": "module",
  "description": "A data-driven browser F1 simulator component for project portfolios.",
  "main": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    }
  },
  "files": [
    "AGENTS.md",
    "assets",
    "docs",
    "src/*.js",
    "README.md"
  ],
