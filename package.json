{
  "name": "@inventure71/paddockjs",
  "version": "0.2.0",
  "type": "module",
  "description": "A data-driven browser F1 simulator component for host websites.",
  "license": "Apache-2.0",
  "author": "Matteo Giorgetti",
  "homepage": "https://github.com/Inventure71/PaddockJS#readme",
  "bugs": {
    "url": "https://github.com/Inventure71/PaddockJS/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inventure71/PaddockJS.git"
  },
  "keywords": [
    "f1",
    "formula-1",
    "motorsport",
    "racing",
    "simulator",
    "timing-tower",
    "pixijs",
    "ui-component"
  ],
  "sideEffects": [
    "./src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./environment": {
      "types": "./src/environment/index.d.ts",
      "import": "./src/environment/index.js",
      "default": "./src/environment/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "CHANGELOG.md",
    "INSTALL_AND_UPDATE.md",
    "LICENSE",
    "assets",
    "docs/*.md",
    "examples",
    "src/api",
    "src/app",
    "src/config",
    "src/data",
    "src/environment",
    "src/rendering",
    "src/simulation",
    "src/ui",
    "src/index.d.ts",
    "src/index.js",
    "src/styles.css",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run src",
    "types:check": "tsc -p tsconfig.types.json --noEmit",
    "check": "npm test && npm run types:check && npm run pack:dry && npm run showcase:ci",
    "pack:dry": "npm pack --dry-run",
    "showcase:install": "npm --prefix local-preview ci",
    "showcase:dev": "npm --prefix local-preview run dev",
    "showcase:build": "npm --prefix local-preview run build",
    "showcase:ci": "npm --prefix local-preview ci && npm --prefix local-preview run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm publish --provenance",
    "example:train": "node examples/train-basic-policy.mjs"
  },
  "dependencies": {
    "pixi.js": "8.18.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
