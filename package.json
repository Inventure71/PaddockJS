    "test": "vitest run src",
    "check": "npm test && npm run pack:dry",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "pixi.js": "8.18.1"
  },
  "devDependencies": {
    "vitest": "4.1.5"
  }
}
